{
	"name": "@vnphanquang/eslint-config",
	"version": "4.2.1",
	"type": "module",
	"main": "src/index.js",
	"types": "types/index.d.ts",
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"import": "./src/index.js"
		}
	},
	"author": "Quang Phan",
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vnphanquang/jsconfig.git"
	},
	"files": [
		"src",
		"types",
		"README.md"
	],
	"bugs": {
		"url": "https://github.com/vnphanquang/jsconfig/issues"
	},
	"homepage": "https://github.com/vnphanquang/jsconfig/tree/main/pacakges/eslint-config",
	"keywords": [
		"eslint",
		"config",
		"vnphanquang"
	],
	"scripts": {
		"lint": "eslint .",
		"format": "prettier --check \"./**/*.{ts,js,cjs,json}\"",
		"dts": "dts-buddy --write && publint",
		"prepublishOnly": "pnpm dts"
	},
	"peerDependencies": {
		"eslint": ">=9.0.0",
		"eslint-plugin-svelte": "^3.20.0"
	},
	"peerDependenciesMeta": {
		"eslint-plugin-svelte": {
			"optional": true
		}
	},
	"dependencies": {
		"@eslint/js": "^10.0.1",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-import-x": "^4.17.1",
		"globals": "^17.7.0",
		"typescript-eslint": "^8.62.0"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.68.0",
		"@vnphanquang/prettierrc": "workspace:*",
		"eslint": "^10.6.0",
		"eslint-plugin-svelte": "^3.20.0",
		"prettier": "^3.9.1",
		"typescript": "^6.0.3"
	}
}
